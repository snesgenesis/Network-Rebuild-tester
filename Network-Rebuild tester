#!/usr/bin/env bash

set -e

GATEWAY_DIR="/home/centegix/gateway"
REBUILD_SCRIPT="scripts/rebuild_network.js"

echo "===== Centegix Network Rebuild ====="

echo "Changing directory to $GATEWAY_DIR"

cd "$GATEWAY_DIR" || {
    echo "ERROR: Cannot change to $GATEWAY_DIR"
    exit 1
}

sleep 3

echo "Stopping forever processes..."
forever stopall || true

sleep 3

run_rebuild() {

  WAIT="$1"

  echo ""
  echo "Running rebuild_network.js for ${WAIT}s..."

  node "$REBUILD_SCRIPT" &
  PID=$!

  sleep "$WAIT"

  echo "Sending Ctrl+C to PID $PID"
  kill -SIGINT "$PID" 2>/dev/null || true
  wait "$PID" 2>/dev/null || true
}

# Rebuild cycles
run_rebuild 12
run_rebuild 12
run_rebuild 12
run_rebuild 45

echo ""
echo "Restarting gateway..."

sudo -u centegix FOREVER_ROOT=/tmp/forever \
forever --minUptime 1 start "$GATEWAY_DIR/index.js"

sleep 3

echo ""
echo "Following logs..."

sudo -u centegix FOREVER_ROOT=/tmp/forever \
forever logs 0 -f
